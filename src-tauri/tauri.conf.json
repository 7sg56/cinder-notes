{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Cinder Notes",
  "version": "0.2.0",
  "identifier": "com.cindernotes.main",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Cinder Notes",
        "width": 1000,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false,
        "visible": false,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 10,
          "y": 20
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENGMkEyMTlEQjJENDlBQjQKUldTMG10U3luU0Vxejl2N0FkT3VHclpiMW02R0lZLzB2K2QvVG1vVC8yMExXT1o2dTdEYXBtNnoK",
      "endpoints": [
        "https://github.com/7sg56/cinder-notes/releases/latest/download/latest.json"
      ]
    }
  }
}
